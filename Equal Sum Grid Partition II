class Solution:
    def canPartitionGrid(self, grid):
        m, n = len(grid), len(grid[0])
        total = sum(sum(row) for row in grid)
        
        # Build value frequency map
        from collections import Counter
        full_count = Counter()
        for row in grid:
            full_count.update(row)
        
        # Prefix row sums
        row_prefix = [0]*m
        for i in range(m):
            row_prefix[i] = sum(grid[i]) + (row_prefix[i-1] if i else 0)
        
        # Prefix col sums
        col_prefix = [0]*n
        for j in range(n):
            s = 0
            for i in range(m):
                s += grid[i][j]
            col_prefix[j] = s + (col_prefix[j-1] if j else 0)
        
        # Check removable
        def can_remove(count_map, r1, r2, c1, c2, diff):
            rows = r2 - r1 + 1
            cols = c2 - c1 + 1
            
            # 2D grid → ANY cell allowed
            if rows > 1 and cols > 1:
                return count_map.get(diff, 0) > 0
            
            # single row
            if rows == 1:
                return grid[r1][c1] == diff or grid[r1][c2] == diff
            
            # single column
            if cols == 1:
                return grid[r1][c1] == diff or grid[r2][c1] == diff
            
            return False
        
        # Horizontal cuts
        top_count = Counter()
        for i in range(m - 1):
            for val in grid[i]:
                top_count[val] += 1
                full_count[val] -= 1
                if full_count[val] == 0:
                    del full_count[val]
            
            top = row_prefix[i]
            bottom = total - top
            
            if top == bottom:
                return True
            
            diff = abs(top - bottom)
            
            if top > bottom:
                if can_remove(top_count, 0, i, 0, n-1, diff):
                    return True
            else:
                if can_remove(full_count, i+1, m-1, 0, n-1, diff):
                    return True
        
        # Rebuild for vertical
        full_count = Counter()
        for row in grid:
            full_count.update(row)
        
        left_count = Counter()
        
        for j in range(n - 1):
            for i in range(m):
                val = grid[i][j]
                left_count[val] += 1
                full_count[val] -= 1
                if full_count[val] == 0:
                    del full_count[val]
            
            left = col_prefix[j]
            right = total - left
            
            if left == right:
                return True
            
            diff = abs(left - right)
            
            if left > right:
                if can_remove(left_count, 0, m-1, 0, j, diff):
                    return True
            else:
                if can_remove(full_count, 0, m-1, j+1, n-1, diff):
                    return True
        
        return False
