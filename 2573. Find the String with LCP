class Solution:
    def findTheString(self, lcp):
        n = len(lcp)
        
        # Step 1: validate diagonal and symmetry
        for i in range(n):
            if lcp[i][i] != n - i:
                return ""
            for j in range(n):
                if lcp[i][j] != lcp[j][i]:
                    return ""
        
        # Step 2: build string
        s = ['?'] * n
        ch = 'a'
        
        for i in range(n):
            if s[i] == '?':
                if ch > 'z':
                    return ""
                s[i] = ch
                for j in range(i + 1, n):
                    if lcp[i][j] > 0:
                        s[j] = ch
                ch = chr(ord(ch) + 1)
        
        s = ''.join(s)
        
        # Step 3: verify LCP
        dp = [[0] * (n + 1) for _ in range(n + 1)]
        
        for i in range(n - 1, -1, -1):
            for j in range(n - 1, -1, -1):
                if s[i] == s[j]:
                    dp[i][j] = dp[i + 1][j + 1] + 1
        
        for i in range(n):
            for j in range(n):
                if dp[i][j] != lcp[i][j]:
                    return ""
        
        return s
